# NextAuth Configuration
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# JWT secret for signing auth tokens (min 32 chars, keep secret)
JWT_SECRET=your_jwt_secret_here_change_this_in_production

# Initial admin account (seeded on first startup when DB is empty)
ADMIN_EMAIL=admin@freshkitchen.com
ADMIN_PASSWORD=changeme
ADMIN_NAME=Admin

# Internal backend URL used by NextAuth server-side (Docker: http://backend:8080, local: http://localhost:8080)
BACKEND_INTERNAL_URL=http://backend:8080

# Stripe Configuration
STRIPE_ENABLED=false
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# MongoDB Configuration
MONGO_URI=mongodb://mongodb:27017/freshkitchen
