# Dev mode: skip Google OAuth entirely (NEXTAUTH_SECRET still required, can be any random string)
DEV_AUTH_BYPASS=false
NEXT_PUBLIC_DEV_AUTH_BYPASS=false

# Google OAuth Configuration (not required when DEV_AUTH_BYPASS=true)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# NextAuth Configuration
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Stripe Configuration
STRIPE_ENABLED=false
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# MongoDB Configuration
MONGO_URI=mongodb://mongodb:27017/freshkitchen
